<section class="mkm-teaser">
  <div class="mkm-teaser__inner">

    <!-- Left -->
    <div class="mkm-teaser__left mkm-wrap" style="padding-left:20px;padding-right:20px;">
      <div>
        <span class="mkm-label mkm-label--paper">nächstes gel · Q3 2026</span>
        <div class="mkm-teaser__num"><sup>n°</sup>4</div>
      </div>
      <h2 class="mkm-teaser__title">Cola.</h2>
      <p class="mkm-teaser__sub">
        13 Zutaten. 30 g Carbs. Koffein aus natürlicher Quelle.
        Entwickelt für den letzten Anstieg, die letzte Runde, den letzten Kilometer.
      </p>
      <div class="mkm-teaser__badge">
        <span>○</span>
        <span>feldtest · 06 / 2026</span>
      </div>
    </div>

    <!-- Right: ingredient list -->
    <div class="mkm-teaser__right mkm-wrap" style="padding-left:20px;padding-right:20px;">
      <div class="mkm-cola-head">
        <span class="mkm-label mkm-label--paper">zutaten · n°4 cola</span>
        <h4>13 Zutaten · 30 g Carbs/Gel</h4>
      </div>

      <div class="mkm-cola-ingr">
        {%- assign cola_ingr = "Maltodextrin|Isomaltulose|Dextrose|Fructose|Wasser|Salz|Natriumcitrat|Zitronensäure|Cola Aroma|Kaliumchlorid|Kaliumsorbat|Xanthan|Natriumbenzoat" | split: "|" -%}
        {%- for item in cola_ingr -%}
          <div class="mkm-cola-ingr__row" style="grid-template-columns:1fr;">
            <span class="mkm-cola-ingr__name">{{ item }}</span>
          </div>
        {%- endfor -%}
      </div>

      <p style="margin-top:20px;font-family:var(--mk-font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,232,0.25);line-height:1.7;">
        in entwicklung · Änderungen vorbehalten · n°4
      </p>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "mkm. n°4 Teaser",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "mkm. n°4 Teaser" }]
}
{% endschema %}
