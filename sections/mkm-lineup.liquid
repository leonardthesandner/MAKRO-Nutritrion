<section class="mkm-lineup" id="lineup">
  <div class="mkm-lineup__header mkm-wrap">
    <div>
      <span class="mkm-label">die reihe · 2026</span>
      <h2 class="mkm-lineup__title">n°1 — n°5.</h2>
    </div>
    <span class="mkm-label" style="padding-bottom:6px;">01 verfügbar · 04 bald</span>
  </div>

  <div class="mkm-lineup__scroll">
    <div class="mkm-lineup__row">

      <!-- n°1 coming soon -->
      <div class="mkm-card mkm-card--soon">
        <div class="mkm-card__top">
          <span class="mkm-label"><span class="mkm-card__status-dot"></span>bald</span>
          <span class="mkm-label">n°1</span>
        </div>
        <div class="mkm-card__body">
          <div class="mkm-card__num"><sup>n°</sup>1</div>
          <div class="mkm-card__icon">
            <svg viewBox="0 0 80 40" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
              <path d="M4 20 q18-14 36 0 t36 0"/>
            </svg>
          </div>
          <div class="mkm-card__name">—</div>
          <div class="mkm-card__tag">in entwicklung</div>
        </div>
        <div class="mkm-card__foot">
          <span class="mkm-label">tba</span>
          <span class="mkm-card__arrow">○</span>
        </div>
      </div>

      <!-- n°2 coming soon -->
      <div class="mkm-card mkm-card--soon">
        <div class="mkm-card__top">
          <span class="mkm-label"><span class="mkm-card__status-dot"></span>bald</span>
          <span class="mkm-label">n°2</span>
        </div>
        <div class="mkm-card__body">
          <div class="mkm-card__num"><sup>n°</sup>2</div>
          <div class="mkm-card__icon">
            <svg viewBox="0 0 80 40" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
              <path d="M4 36 A 36 36 0 0 1 76 36"/>
              <path d="M16 36 A 24 24 0 0 1 64 36"/>
            </svg>
          </div>
          <div class="mkm-card__name">—</div>
          <div class="mkm-card__tag">in entwicklung</div>
        </div>
        <div class="mkm-card__foot">
          <span class="mkm-label">tba</span>
          <span class="mkm-card__arrow">○</span>
        </div>
      </div>

      <!-- n°3 AKTIV -->
      <a class="mkm-card mkm-card--active" href="{{ routes.collections_url }}">
        <div class="mkm-card__top">
          <span class="mkm-label"><span class="mkm-card__status-dot"></span>verfügbar</span>
          <span class="mkm-label">n°3</span>
        </div>
        <div class="mkm-card__body">
          <div class="mkm-card__num"><sup>n°</sup>3</div>
          <div class="mkm-card__icon">
            <svg viewBox="0 0 120 50" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round">
              <path d="M5 14 q27.5-12 55 0 t55 0"/>
              <path d="M5 28 q27.5-12 55 0 t55 0"/>
              <path d="M5 42 q27.5-12 55 0 t55 0"/>
            </svg>
          </div>
          <div class="mkm-card__name">endurance</div>
          <div class="mkm-card__tag">30 g carbs · 60 g</div>
        </div>
        <div class="mkm-card__foot">
          <span class="mkm-label" style="color:var(--mk-ink);">ab € 3,20</span>
          <span class="mkm-card__arrow" style="color:var(--mk-ink);">→</span>
        </div>
      </a>

      <!-- n°4 Cola coming soon -->
      <div class="mkm-card mkm-card--soon">
        <div class="mkm-card__top">
          <span class="mkm-label"><span class="mkm-card__status-dot"></span>Q3/26</span>
          <span class="mkm-label">n°4</span>
        </div>
        <div class="mkm-card__body">
          <div class="mkm-card__num"><sup>n°</sup>4</div>
          <div class="mkm-card__icon">
            <svg viewBox="0 0 80 110" fill="currentColor">
              <path d="M44 0 L8 60 L32 60 L24 110 L66 44 L42 44 Z" opacity="0.3"/>
            </svg>
          </div>
          <div class="mkm-card__name">cola</div>
          <div class="mkm-card__tag">+ koffein · feldtest</div>
        </div>
        <div class="mkm-card__foot">
          <span class="mkm-label">Q3 / 2026</span>
          <span class="mkm-card__arrow">○</span>
        </div>
      </div>

      <!-- n°5 coming soon -->
      <div class="mkm-card mkm-card--soon">
        <div class="mkm-card__top">
          <span class="mkm-label"><span class="mkm-card__status-dot"></span>bald</span>
          <span class="mkm-label">n°5</span>
        </div>
        <div class="mkm-card__body">
          <div class="mkm-card__num"><sup>n°</sup>5</div>
          <div class="mkm-card__icon">
            <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
              <line x1="10" y1="30" x2="50" y2="30"/>
              <line x1="30" y1="10" x2="30" y2="50"/>
            </svg>
          </div>
          <div class="mkm-card__name">—</div>
          <div class="mkm-card__tag">in planung</div>
        </div>
        <div class="mkm-card__foot">
          <span class="mkm-label">tba</span>
          <span class="mkm-card__arrow">○</span>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "mkm. Lineup",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "mkm. Lineup" }]
}
{% endschema %}
