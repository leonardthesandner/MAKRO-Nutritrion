<section class="mkm-science" id="science">
  <div class="mkm-science__inner mkm-wrap">

    <!-- Header -->
    <div class="mkm-science__head">
      <span class="mkm-label">wissenschaft · kohlenhydrate</span>
      <h2 class="mkm-science__title">Vier Quellen.<br>Eine Strategie.</h2>
      <p class="mkm-science__intro">
        makro. kombiniert vier Kohlenhydrate mit unterschiedlichen Aufnahmegeschwindigkeiten —
        sofortige Energie zu Beginn, gleichmäßige Versorgung bis ans Ende.
      </p>
    </div>

    <!-- Absorption Chart -->
    <div class="mkm-chart-wrap mkm-fade-in">
      <div class="mkm-chart__title">Energieverfügbarkeit im Vergleich · schematisch</div>

      <div class="mkm-chart">
        <div class="mkm-chart__y">
          <span>hoch</span>
          <span>mittel</span>
          <span>niedrig</span>
        </div>
        <div class="mkm-chart__plot">
          <svg viewBox="0 0 480 180" preserveAspectRatio="none" aria-hidden="true">

            <!-- Grid -->
            <line x1="0" y1="45"  x2="480" y2="45"  stroke="currentColor" stroke-width="0.5" stroke-opacity="0.10"/>
            <line x1="0" y1="90"  x2="480" y2="90"  stroke="currentColor" stroke-width="0.5" stroke-opacity="0.10"/>
            <line x1="0" y1="135" x2="480" y2="135" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.10"/>
            <line x1="0" y1="175" x2="480" y2="175" stroke="currentColor" stroke-width="1"   stroke-opacity="0.18"/>

            <!-- Fructose: dashed, warm grey — mittlere Aufnahme, leberabhängig -->
            <path d="M0,175 C50,174 90,140 130,115 C165,93 200,80 240,78 C280,76 315,90 360,103 C405,115 445,130 480,138"
                  fill="none" stroke="#B0A898" stroke-width="2" stroke-linecap="round" stroke-dasharray="6 4"/>

            <!-- Maltodextrin: medium grey — schnelle Glucoseketten -->
            <path d="M0,175 C40,168 75,28 125,22 C162,18 188,42 218,70 C258,108 308,143 360,156 C405,164 445,169 480,171"
                  fill="none" stroke="#7A7571" stroke-width="2" stroke-linecap="round"/>

            <!-- Dextrose: dark grey — direkter Spike -->
            <path d="M0,175 C28,170 52,14 96,11 C128,9 152,46 184,77 C224,118 284,152 360,164 C405,169 445,172 480,173"
                  fill="none" stroke="#3D3D3D" stroke-width="2" stroke-linecap="round"/>

            <!-- Isomaltulose: ink — langsam, anhaltend (Helden-Kurve) -->
            <path d="M0,175 C58,174 94,162 138,148 C178,134 214,108 254,92 C294,77 330,66 360,65 C395,64 442,69 480,76"
                  fill="none" stroke="#0E0E0E" stroke-width="2.5" stroke-linecap="round"/>

          </svg>

          <!-- X-axis labels -->
          <div class="mkm-chart__x">
            <span>0</span>
            <span>30 min</span>
            <span>60 min</span>
            <span>90 min</span>
            <span>120 min</span>
          </div>
        </div>
      </div>

      <!-- Legend -->
      <div class="mkm-chart__legend">
        <div class="mkm-chart__legend-item">
          <svg width="32" height="10" viewBox="0 0 32 10" aria-hidden="true">
            <line x1="0" y1="5" x2="32" y2="5" stroke="#0E0E0E" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span>Isomaltulose</span>
        </div>
        <div class="mkm-chart__legend-item">
          <svg width="32" height="10" viewBox="0 0 32 10" aria-hidden="true">
            <line x1="0" y1="5" x2="32" y2="5" stroke="#3D3D3D" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span>Dextrose</span>
        </div>
        <div class="mkm-chart__legend-item">
          <svg width="32" height="10" viewBox="0 0 32 10" aria-hidden="true">
            <line x1="0" y1="5" x2="32" y2="5" stroke="#7A7571" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span>Maltodextrin</span>
        </div>
        <div class="mkm-chart__legend-item">
          <svg width="32" height="10" viewBox="0 0 32 10" aria-hidden="true">
            <line x1="0" y1="5" x2="32" y2="5" stroke="#B0A898" stroke-width="2" stroke-dasharray="5 3" stroke-linecap="round"/>
          </svg>
          <span>Fructose</span>
        </div>
      </div>

      <p class="mkm-chart__disclaimer">schematisch · nicht nach klinischen studien · zur orientierung</p>
    </div>

    <!-- Ingredient Cards -->
    <div class="mkm-sci-cards">

      <div class="mkm-sci-card mkm-sci-card--hero">
        <div class="mkm-sci-card__num">01</div>
        <div class="mkm-sci-card__name">Isomaltulose</div>
        <div class="mkm-sci-card__tag">langsam · GI ≈ 32 · anhaltend</div>
        <p class="mkm-sci-card__desc">
          Aus Zuckerrüben gewonnen. Wird langsam und gleichmäßig aufgespalten —
          kein Insulin-Spike, kein Einbruch. Liefert stabile Energie über die gesamte
          Belastung und unterstützt gleichzeitig die Fettoxidation.
        </p>
      </div>

      <div class="mkm-sci-card">
        <div class="mkm-sci-card__num">02</div>
        <div class="mkm-sci-card__name">Dextrose</div>
        <div class="mkm-sci-card__tag">sofort · GI ≈ 100 · direkt</div>
        <p class="mkm-sci-card__desc">
          Reine Glucose — der direkteste Kraftstoff für Muskeln und Gehirn.
          Innerhalb von Minuten verfügbar. Ideal für intensive Belastungsphasen,
          in denen sofortige Energie über Sieg oder Einbruch entscheidet.
        </p>
      </div>

      <div class="mkm-sci-card">
        <div class="mkm-sci-card__num">03</div>
        <div class="mkm-sci-card__name">Maltodextrin</div>
        <div class="mkm-sci-card__tag">schnell · GI ≈ 85–105 · magenfreundlich</div>
        <p class="mkm-sci-card__desc">
          Kurze Glucoseketten aus Stärke — schnell verfügbar, ohne den intensiven
          Süßegeschmack reiner Zucker. Hohe Kohlenhydratdichte bei guter
          Magenverträglichkeit, auch unter maximaler Belastung.
        </p>
      </div>

      <div class="mkm-sci-card">
        <div class="mkm-sci-card__num">04</div>
        <div class="mkm-sci-card__name">Fructose</div>
        <div class="mkm-sci-card__tag">mittel · GI ≈ 25 · leberpfad</div>
        <p class="mkm-sci-card__desc">
          Wird über die Leber metabolisiert — unabhängig vom Glucose-Transporter.
          Ermöglicht eine Gesamtaufnahme von bis zu 90 g Kohlenhydraten pro Stunde
          ohne Verdauungsprobleme.
        </p>
      </div>

    </div>

  </div>
</section>

