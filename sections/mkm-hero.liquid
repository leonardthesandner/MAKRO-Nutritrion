<section class="mkm-hero">
  <div class="mkm-hero__inner">

    <!-- 1. Text: Label + Numeral + Titel + Beschreibung -->
    <div class="mkm-hero__text">
      <div class="mkm-hero__eyebrow">
        <span class="mkm-label">n°1 · endurance</span>
        <span class="mkm-label">ab € 3,20 · verfügbar</span>
      </div>
      <div>
        <div class="mkm-hero__numeral"><sup>n°</sup>1</div>
        <h1 class="mkm-hero__title">{{ section.settings.title }}</h1>
        <p class="mkm-hero__desc" style="margin-top:16px;">{{ section.settings.desc }}</p>
      </div>
    </div>

    <!-- 2. Produktbilder Swiper -->
    <div class="mkm-hero__image-wrap">
      <div class="mkm-swiper" id="mkm-hero-swiper">
        <div class="mkm-swiper__track">
          <div class="mkm-swiper__slide">
            <img
              class="mkm-hero__img"
              src="{{ 'swipebild-1.png' | asset_url }}"
              alt="makro. n°1 endurance – Ansicht 1"
              loading="eager"
              fetchpriority="high"
            >
          </div>
          <div class="mkm-swiper__slide">
            <img
              class="mkm-hero__img"
              src="{{ 'swipebild-2.png' | asset_url }}"
              alt="makro. n°1 endurance – Ansicht 2"
              loading="lazy"
            >
          </div>
          <div class="mkm-swiper__slide">
            <img
              class="mkm-hero__img"
              src="{{ 'swipebild-3.png' | asset_url }}"
              alt="makro. n°1 endurance – Ansicht 3"
              loading="lazy"
            >
          </div>
          <div class="mkm-swiper__slide">
            <img
              class="mkm-hero__img"
              src="{{ 'swipebild-4.png' | asset_url }}"
              alt="makro. n°1 endurance – Ansicht 4"
              loading="lazy"
            >
          </div>
        </div>
        <div class="mkm-swiper__dots" role="tablist" aria-label="Produktbilder">
          <button class="mkm-swiper__dot is-active" data-index="0" aria-label="Bild 1"></button>
          <button class="mkm-swiper__dot" data-index="1" aria-label="Bild 2"></button>
          <button class="mkm-swiper__dot" data-index="2" aria-label="Bild 3"></button>
          <button class="mkm-swiper__dot" data-index="3" aria-label="Bild 4"></button>
        </div>
      </div>
    </div>

    <!-- 3. Bottom: Specs-Leiste + CTA Buttons -->
    <div class="mkm-hero__bottom">
      <div class="mkm-hero__specs">
        <div class="mkm-hero__spec">
          <div class="mkm-hero__spec-val">30 g</div>
          <div class="mkm-hero__spec-key">Carbs</div>
        </div>
        <div class="mkm-hero__spec">
          <div class="mkm-hero__spec-val">60 g</div>
          <div class="mkm-hero__spec-key">Net Wt.</div>
        </div>
        <div class="mkm-hero__spec">
          <div class="mkm-hero__spec-val">92 kcal</div>
          <div class="mkm-hero__spec-key">Energie</div>
        </div>
      </div>
      <div class="mkm-hero__cta">
        <a href="{{ section.settings.cta_link | default: routes.collections_url }}" class="mkm-hero__btn">
          <span>{{ section.settings.cta_label | default: 'jetzt kaufen' }}</span>
          <span>→</span>
        </a>
        <a href="/pages/science" class="mkm-hero__btn mkm-hero__btn--ghost">
          <span>mehr erfahren</span>
          <span>→</span>
        </a>
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var swiper = document.getElementById('mkm-hero-swiper');
  if (!swiper) return;
  var track = swiper.querySelector('.mkm-swiper__track');
  var dots  = swiper.querySelectorAll('.mkm-swiper__dot');
  var current = 0;

  function goTo(index) {
    track.scrollTo({ left: track.offsetWidth * index, behavior: 'smooth' });
  }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      goTo(parseInt(dot.dataset.index));
    });
  });

  track.addEventListener('scroll', function() {
    var idx = Math.round(track.scrollLeft / track.offsetWidth);
    if (idx !== current) {
      current = idx;
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === current); });
    }
  }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "mkm. Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Headline", "default": "endurance." },
    { "type": "text", "id": "desc", "label": "Beschreibung", "default": "Isomaltulose & Dextrose. 30 g Carbs pro Gel. Kein Crash. Kein Hype. Nur Energie, die hält." },
    { "type": "url", "id": "cta_link", "label": "CTA Link" },
    { "type": "text", "id": "cta_label", "label": "CTA Text", "default": "jetzt kaufen" }
  ],
  "presets": [{ "name": "mkm. Hero" }]
}
{% endschema %}
