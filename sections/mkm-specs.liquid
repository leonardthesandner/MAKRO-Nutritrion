<section class="mkm-specs">
  <div class="mkm-specs__solo mkm-wrap">

    <div class="mkm-specs__head">
      <span class="mkm-label">n°1 · nährwerte</span>
      <h2 class="mkm-specs__title">Was drinsteckt.</h2>
    </div>

    <div class="mkm-specs__right-col">

      <!-- EU-konforme Nährwerttabelle -->
      <div class="mkm-label-box">
        <div class="mkm-label-box__head">
          <h3>Nährwertangaben</h3>
          <p>pro Portion (60 g Gel) · n°1 endurance</p>
        </div>

        <div class="mkm-label-box__row mkm-label-box__row--bold">
          <span class="mkm-label-box__key">Energie</span>
          <span class="mkm-label-box__val">385 kJ / 92 kcal</span>
        </div>
        <div class="mkm-label-box__row">
          <span class="mkm-label-box__key">Fett</span>
          <span class="mkm-label-box__val">0 g</span>
        </div>
        <div class="mkm-label-box__row">
          <span class="mkm-label-box__key mkm-label-box__key--sub">davon gesättigte Fettsäuren</span>
          <span class="mkm-label-box__val">0 g</span>
        </div>
        <div class="mkm-label-box__row mkm-label-box__row--bold">
          <span class="mkm-label-box__key">Kohlenhydrate</span>
          <span class="mkm-label-box__val">30 g</span>
        </div>
        <div class="mkm-label-box__row">
          <span class="mkm-label-box__key mkm-label-box__key--sub">davon Zucker</span>
          <span class="mkm-label-box__val">30 g</span>
        </div>
        <div class="mkm-label-box__row">
          <span class="mkm-label-box__key">Eiweiß</span>
          <span class="mkm-label-box__val">0 g</span>
        </div>
        <div class="mkm-label-box__row">
          <span class="mkm-label-box__key">Salz</span>
          <span class="mkm-label-box__val">0,28 g</span>
        </div>

        <div class="mkm-label-box__footer">
          Net Wt. 60 g · n°1 endurance · Hergestellt in Bayern · DE<br>
          <span style="font-size:9px;opacity:0.6;">* Referenzwert: 8.400 kJ / 2.000 kcal</span>
        </div>
      </div>

      <!-- Kohlenhydrat-Profil -->
      <div class="mkm-carb-profile">
        <span class="mkm-label">kohlenhydrat-profil · pro portion</span>
        <div class="mkm-carb-profile__grid">
          <div>
            <div class="mkm-carb-profile__val">15 g</div>
            <div class="mkm-carb-profile__name">Isomaltulose</div>
            <div class="mkm-carb-profile__note">niedriger GI</div>
          </div>
          <div>
            <div class="mkm-carb-profile__val">8 g</div>
            <div class="mkm-carb-profile__name">Dextrose</div>
            <div class="mkm-carb-profile__note">sofort</div>
          </div>
          <div>
            <div class="mkm-carb-profile__val">7 g</div>
            <div class="mkm-carb-profile__name">Fructose</div>
            <div class="mkm-carb-profile__note">leberpfad</div>
          </div>
        </div>
      </div>

      <!-- Zutatenliste in Zeilenform -->
      <p class="mkm-ingr-line">
        <strong>Zutaten:</strong>
        Wasser, Isomaltulose, Dextrose, Fructose, Salz, Natriumcitrat, Zitronensäure, Aroma, Kaliumchlorid, Kaliumsorbat, Xanthan, Natriumbenzoat.
      </p>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); }
      });
    }, { threshold: 0.2 });
    document.querySelectorAll('.mkm-fade-in').forEach(function(el) { observer.observe(el); });
  });
</script>

{% schema %}
{
  "name": "mkm. Specs",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "mkm. Specs" }]
}
{% endschema %}
